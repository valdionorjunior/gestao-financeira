# ============================================================
# GESTÃO FINANCEIRA PESSOAL FAMILIAR - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores

# --- APLICAÇÃO ---
NODE_ENV=development
API_PORT=3000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# --- BANCO DE DADOS (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financial_management
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_SSL=false

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_TTL=3600

# --- JWT ---
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# --- OAUTH2 GOOGLE ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# --- CRIPTOGRAFIA (AES-256) ---
ENCRYPTION_KEY=change_this_32_bytes_hex_key_here
ENCRYPTION_IV=change_this_16_bytes_iv

# --- RATE LIMITING ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=20

# --- OPENAI (Módulo IA) ---
OPENAI_API_KEY=your_openai_api_key

# --- GOOGLE VISION (OCR) ---
GOOGLE_VISION_API_KEY=your_google_vision_api_key

# --- EMAIL ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

# --- FLYWAY ---
FLYWAY_URL=jdbc:postgresql://localhost:5432/financial_management
FLYWAY_USER=postgres
FLYWAY_PASSWORD=change_this_password
FLYWAY_LOCATIONS=filesystem:./migrations

# --- LOGS ---
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
