# ============================================================
# BACKEND - Variáveis de Ambiente
# ============================================================
NODE_ENV=development
API_PORT=3000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

DB_HOST=postgres
DB_PORT=5432
DB_NAME=financial_management
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_SSL=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password
REDIS_TTL=3600

JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

ENCRYPTION_KEY=change_this_32_bytes_hex_key_here
ENCRYPTION_IV=change_this_16_bytes_iv

THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=20

OPENAI_API_KEY=your_openai_api_key
GOOGLE_VISION_API_KEY=your_google_vision_api_key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password

LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
