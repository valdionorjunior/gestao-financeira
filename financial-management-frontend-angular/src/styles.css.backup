/* ═══════════════════════════════════════════════════════════
   🎨 FINANCIAL APP - MODERN DESIGN SYSTEM 2026
   Nova identidade: Nubank + Wise + Apple = Experiência premium
   Paleta: Ultra violeta + Verde menta + Coral
═══════════════════════════════════════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
@import url('https://fonts.googleapis.com/css2?family=CalSans-SemiBold&display=swap');
@import "primeicons/primeicons.css";

/* Tailwind v4 — modo nativo */
@import "tailwindcss";
@source "./app/**/*.ts";
@source "./app/**/*.html";

:root {
  /* 🎨 NOVA PALETA FINANCEIRA - 2026 */
  --primary-50:  #F3F2FF;
  --primary-100: #E8E5FF;
  --primary-200: #D4CFFF;
  --primary-300: #B8AFFF;
  --primary-400: #9A8CFF;
  --primary-500: #6C5CE7;  /* Ultra violeta - Principal */
  --primary-600: #5B4BD6;
  --primary-700: #4A3CB8;
  --primary-800: #3A2E94;
  --primary-900: #2E2477;
  
  --secondary-50:  #E6FFF7;
  --secondary-100: #B3FFE6;
  --secondary-200: #80FFD4;
  --secondary-300: #4DFFC2;
  --secondary-400: #1AFFB1;
  --secondary-500: #00D4AA;  /* Verde menta - Crescimento */
  --secondary-600: #00B894;
  --secondary-700: #009B7D;
  --secondary-800: #007E66;
  --secondary-900: #006250;
  
  --accent-50:  #FFF0F0;
  --accent-100: #FFD7D7;
  --accent-200: #FFBBBB;
  --accent-300: #FF9999;
  --accent-400: #FF7777;
  --accent-500: #FF6B6B;  /* Coral - Alertas */
  --accent-600: #E85555;
  --accent-700: #CC4444;
  --accent-800: #B03333;
  --accent-900: #942222;
  
  /* 🌈 CONTEXTO FINANCEIRO */
  --income:      var(--secondary-500);    /* Verde menta para receitas */
  --expense:     var(--accent-500);       /* Coral para despesas */
  --transfer:    var(--primary-500);      /* Violeta para transferências */
  --investment:  #3B82F6;                 /* Azul para investimentos */
  
  /* 🏗️ SUPERFÍCIES MODERNAS */
  --surface-ground:    #F8FAFF;           /* Azul ghost ultra suave */
  --surface-card:      #FFFFFF;
  --surface-elevated:  #FCFCFD;
  --surface-border:    rgba(108, 92, 231, 0.08);
  --surface-hover:     rgba(108, 92, 231, 0.04);
  
  /* 📝 TIPOGRAFIA SYSTEM */
  --text-primary:      #2D3436;           /* Quase preto para legibilidade */
  --text-secondary:    #636E72;           /* Cinza médio */
  --text-muted:        #B2BEC3;           /* Cinza claro */
  --text-inverse:      #FFFFFF;
  
  /* 🎭 GRADIENTES VIBRANTES */
  --gradient-primary:    linear-gradient(135deg, #6C5CE7 0%, #9A8CFF 100%);
  --gradient-secondary:  linear-gradient(135deg, #00D4AA 0%, #1AFFB1 100%);
  --gradient-accent:     linear-gradient(135deg, #FF6B6B 0%, #FF9999 100%);
  --gradient-glass:      linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
  --gradient-mesh:       radial-gradient(at 27% 37%, hsla(215, 98%, 61%, 1) 0%, transparent 50%), 
                         radial-gradient(at 97% 21%, hsla(125, 98%, 72%, 1) 0%, transparent 50%), 
                         radial-gradient(at 52% 99%, hsla(354, 98%, 61%, 1) 0%, transparent 50%), 
                         radial-gradient(at 10% 29%, hsla(256, 96%, 67%, 1) 0%, transparent 50%);
  
  /* 🔳 ESPAÇAMENTO & BORDAS */
  --radius-xs:   6px;
  --radius-sm:   10px;
  --radius-md:   16px;
  --radius-lg:   20px;
  --radius-xl:   24px;
  --radius-2xl:  32px;
  --radius-full: 9999px;
  
  /* 🌟 SOMBRAS COLORIDAS */
  --shadow-xs:   0 1px 3px rgba(108, 92, 231, 0.04);
  --shadow-sm:   0 2px 8px rgba(108, 92, 231, 0.08);
  --shadow-md:   0 4px 16px rgba(108, 92, 231, 0.12);
  --shadow-lg:   0 8px 24px rgba(108, 92, 231, 0.15);
  --shadow-xl:   0 12px 32px rgba(108, 92, 231, 0.18);
  --shadow-glow: 0 0 20px rgba(108, 92, 231, 0.4);
  --shadow-glow-secondary: 0 0 20px rgba(0, 212, 170, 0.4);
  
  /* ⚡ TRANSIÇÕES FLUIDAS */
  --transition-fast:  150ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --transition-base:  250ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --transition-slow:  350ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --transition-bounce: 400ms cubic-bezier(0.68, -0.55, 0.265, 1.55);
  
  /* 📐 LAYOUT RESPONSIVO */
  --sidebar-width:      280px;
  --sidebar-collapsed:  72px;
  --topbar-height:      72px;
  --content-max-width:  1400px;

  /* 🔄 Aliases para compatibilidade com templates existentes */
  --primary:              var(--primary-500);
  --primary-light:        var(--primary-400);
  --primary-dark:         var(--primary-600);
  --primary-gradient:     var(--gradient-primary);
  --success:              var(--secondary-500);
  --success-gradient:     var(--gradient-secondary);
  --warning:              #F59E0B;
  --warning-gradient:     linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
  --danger:               var(--accent-500);
  --danger-gradient:      var(--gradient-accent);
  --info:                 #3B82F6;
  --info-gradient:        linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  --color-bg:             var(--surface-ground);
  --color-surface:        var(--surface-card);
  --color-border:         var(--surface-border);
  --color-primary:        var(--primary);
  --color-text:           var(--text-primary);
  --color-text-muted:     var(--text-secondary);
  --color-income:         var(--income);
  --color-income-bg:      rgba(0, 212, 170, 0.08);
  --color-expense:        var(--expense);
  --color-expense-bg:     rgba(255, 107, 107, 0.08);
  --color-transfer:       var(--transfer);
  --color-transfer-bg:    rgba(108, 92, 231, 0.08);
  --color-success:        var(--success);
  --color-warning:        var(--warning);
  --color-danger:         var(--danger);
  --primary-color:        var(--primary);
}

/* ═══ BASE RESETS & TYPOGRAPHY ═══ */
*, *::before, *::after { 
  box-sizing: border-box; 
  margin: 0; 
  padding: 0; 
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
}

body {
  height: 100%;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: var(--surface-ground);
  color: var(--text-primary);
  font-feature-settings: 'cv03', 'cv04', 'cv11';
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  font-variant-numeric: tabular-nums;
}

/* ═══ TYPOGRAPHY SCALE ═══ */
.text-display {
  font-family: 'CalSans-SemiBold', 'Inter', sans-serif;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.text-xs { font-size: 0.75rem; line-height: 1rem; }
.text-sm { font-size: 0.875rem; line-height: 1.25rem; }
.text-base { font-size: 1rem; line-height: 1.5rem; }
.text-lg { font-size: 1.125rem; line-height: 1.75rem; }
.text-xl { font-size: 1.25rem; line-height: 1.75rem; }
.text-2xl { font-size: 1.5rem; line-height: 2rem; }
.text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
.text-4xl { font-size: 2.25rem; line-height: 2.5rem; }

/* ═══ SCROLLBAR MODERNO ═══ */
::-webkit-scrollbar { width: 8px; height: 8px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, var(--primary-400), var(--primary-500));
  border-radius: var(--radius-full);
  border: 2px solid transparent;
  background-clip: content-box;
}
::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, var(--primary-500), var(--primary-600));
  background-clip: content-box;
}

/* ═══ FOCUS MODERNO ═══ */
*:focus {
  outline: 2px solid var(--primary-500);
  outline-offset: 2px;
  border-radius: var(--radius-sm);
}
*:focus:not(:focus-visible) { outline: none; }

/* ═══ UTILITY CLASSES ═══ */
.gradient-text {
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.glass-effect {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

a { 
  text-decoration: none; 
  color: inherit; 
  transition: color var(--transition-base); 
}

/* ═══ ANIMAÇÕES AVANÇADAS ═══ */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideInRight {
  from { opacity: 0; transform: translateX(-24px); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-6px); }
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: var(--shadow-md); }
  50% { box-shadow: var(--shadow-glow); }
}

/* Legacy animations for compatibility */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideDown {
  from { opacity: 0; transform: translateY(-12px); }
  to   { opacity: 1; transform: translateY(0); }
}

.animate-fade-in-up { animation: fadeInUp 0.4s ease-out; }
.animate-slide-in-right { animation: slideInRight 0.3s ease-out; }
.animate-scale-in { animation: scaleIn 0.2s ease-out; }
.animate-float { animation: float 3s ease-in-out infinite; }
.animate-pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }

/* ═══ MODERNOS COMPONENTES BASE ═══ */
.card-modern {
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border: 1px solid var(--surface-border);
  transition: all var(--transition-base);
}

.card-modern:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn-primary {
  background: var(--gradient-primary);
  border: none;
  color: var(--text-inverse);
  padding: 0.75rem 1.5rem;
  border-radius: var(--radius-md);
  font-weight: 600;
  font-size: 0.875rem;
  cursor: pointer;
  transition: all var(--transition-base);
  box-shadow: var(--shadow-sm);
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
  filter: brightness(1.05);
}

.btn-primary:active {
  transform: translateY(0);
}

.btn-secondary {
  background: var(--gradient-secondary);
  border: none;
  color: var(--text-inverse);
  padding: 0.75rem 1.5rem;
  border-radius: var(--radius-md);
  font-weight: 600;
  font-size: 0.875rem;
  cursor: pointer;
  transition: all var(--transition-base);
  box-shadow: var(--shadow-sm);
}

.btn-secondary:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
  filter: brightness(1.05);
}

/* ═══ PAGE & LAYOUT MODERNOS ═══ */
.page-container {
  padding: 2rem;
  animation: fadeInUp var(--transition-slow);
  max-width: var(--content-max-width);
  margin: 0 auto;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2.5rem;
  animation: slideInRight var(--transition-base);
}

.page-header h1 {
  font-size: 2.25rem;
  font-weight: 700;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.02em;
  font-family: 'CalSans-SemiBold', 'Inter', sans-serif;
}

.page-header h2 { 
  font-size: 1.875rem; 
  font-weight: 700; 
  color: var(--text-primary);
  letter-spacing: -0.01em; 
}

/* ═══ CARD SYSTEM ═══ */
.card {
  background: var(--surface-card);
  border-radius: var(--radius-xl);
  padding: 2rem;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--surface-border);
  transition: all var(--transition-base);
}

.card:hover {
  box-shadow: var(--shadow-lg);
  border-color: rgba(108, 92, 231, 0.15);
  transform: translateY(-3px);
}

.card-compact { padding: 1.5rem; }
.card-spacious { padding: 3rem; }

/* ═══ GRID RESPONSIVO MODERNO ═══ */
.grid-cards {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
}

.grid-accounts {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
}

/* ═══ KPI CARDS MODERNOS ═══ */
.kpi-card {
  background: var(--surface-card);
  border-radius: var(--radius-xl);
  padding: 2rem;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--surface-border);
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}

.kpi-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--gradient-primary);
}

.kpi-card.income::before { background: var(--gradient-secondary); }
.kpi-card.expense::before { background: var(--gradient-accent); }
.kpi-card.transfer::before { background: var(--gradient-primary); }

.kpi-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-xl);
}

.kpi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.kpi-title {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.kpi-value {
  font-size: 2.25rem;
  font-weight: 700;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}

.kpi-icon {
  width: 3rem;
  height: 3rem;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  color: var(--text-inverse);
  background: var(--gradient-primary);
}

.kpi-icon.income { background: var(--gradient-secondary); }
.kpi-icon.expense { background: var(--gradient-accent); }

/* ═══ LOADING & SKELETON ═══ */
.skeleton {
  background: linear-gradient(90deg, var(--surface-border) 25%, var(--surface-hover) 50%, var(--surface-border) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-md);
}

/* ═══ RESPONSIVIDADE ═══ */
@media (max-width: 768px) {
  html { font-size: 14px; }
  :root {
    --sidebar-width: 280px;
    --topbar-height: 64px;
  }
  .page-container { padding: 1rem; }
  .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .page-header h1 { font-size: 1.875rem; }
  .grid-cards { grid-template-columns: 1fr; }
}

/* ═══ OVERRIDES PRIMENG MODERNOS ═══ */
.p-button {
  font-family: inherit;
  font-weight: 600;
  border-radius: var(--radius-md) !important;
  transition: all var(--transition-base) !important;
}

.p-button-primary {
  background: var(--gradient-primary) !important;
  border: none !important;
}

.p-button-secondary {
  background: var(--gradient-secondary) !important;
  border: none !important;
}

.p-inputtext {
  border-radius: var(--radius-md) !important;
  border-color: var(--surface-border) !important;
  padding: 0.75rem 1rem !important;
}

.p-inputtext:focus {
  border-color: var(--primary-500) !important;
  box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.1) !important;
}

.p-datatable {
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md) !important;
}

.p-card {
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md) !important;
  border: 1px solid var(--surface-border) !important;
}
  --transition-slow: 350ms cubic-bezier(0.4, 0, 0.2, 1);

  /* aliases para compatibilidade com templates existentes */
  --color-bg:          var(--surface-ground);
  --color-surface:     var(--surface-card);
  --color-border:      var(--surface-border);
  --color-primary:     var(--primary);
  --color-text:        var(--text-color);
  --color-text-muted:  var(--text-color-secondary);
  --color-income:      var(--success);
  --color-income-bg:   rgba(16, 185, 129, 0.08);
  --color-expense:     var(--danger);
  --color-expense-bg:  rgba(239, 68, 68, 0.08);
  --color-transfer:    var(--primary);
  --color-transfer-bg: rgba(139, 92, 246, 0.08);
  --color-success:     var(--success);
  --color-warning:     var(--warning);
  --color-danger:      var(--danger);
  /* PrimeNG / legacy compat */
  --primary-color:     var(--primary);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  height: 100%;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
  color: var(--text-color);
  background: var(--surface-ground);
  -webkit-font-smoothing: antialiased;
}

a { text-decoration: none; color: inherit; transition: color var(--transition-base); }

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(139, 92, 246, 0.35); border-radius: var(--radius-full); }
::-webkit-scrollbar-thumb:hover { background: rgba(139, 92, 246, 0.55); }

:focus-visible { outline: 2px solid var(--primary); outline-offset: 2px; border-radius: 4px; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes slideDown {
  from { opacity: 0; transform: translateY(-12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50%       { transform: translateY(-4px); }
}

.animate-fade-in-up { animation: fadeIn 0.3s ease both; }

/* ── Page Layout ─────────────────────────────────────────── */
.page-container {
  padding: 2rem;
  animation: fadeIn var(--transition-base);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  animation: slideDown var(--transition-base);
}

.page-header h1 {
  font-size: 1.875rem;
  font-weight: 700;
  background: var(--primary-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.5px;
}

.page-header h2 { font-size: 1.5rem; font-weight: 700; color: var(--text-color); }

/* ── Card ────────────────────────────────────────────────── */
.card {
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  padding: 2rem;
  box-shadow: var(--shadow-md);
  border: 1px solid rgba(139, 92, 246, 0.1);
  transition: all var(--transition-base);
}

.card:hover {
  box-shadow: var(--shadow-lg);
  border-color: rgba(139, 92, 246, 0.2);
  transform: translateY(-2px);
}

/* 3-column responsive card grid for accounts / budgets / goals */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

/* ── KPI Grid ────────────────────────────────────────────── */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.kpi-card {
  background: var(--surface-card);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  box-shadow: var(--shadow-md);
  border: 1px solid rgba(139, 92, 246, 0.1);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}

.kpi-card::before {
  content: '';
  position: absolute;
  top: -50%; right: -50%;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  transition: all var(--transition-slow);
}

.kpi-card:hover { box-shadow: var(--shadow-lg); border-color: rgba(139, 92, 246, 0.3); transform: translateY(-4px); }
.kpi-card:hover::before { top: -25%; right: -25%; }

.kpi-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}

.kpi-icon {
  width: 56px; height: 56px;
  border-radius: var(--radius-lg);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem; color: white;
  transition: transform var(--transition-base);
  flex-shrink: 0;
}

.kpi-icon:hover { transform: scale(1.08) rotate(5deg); }
.kpi-icon.blue   { background: var(--info-gradient); }
.kpi-icon.green  { background: var(--success-gradient); }
.kpi-icon.red    { background: var(--danger-gradient); }
.kpi-icon.orange { background: var(--warning-gradient); }
.kpi-icon.purple { background: var(--primary-gradient); }

.kpi-info { position: relative; z-index: 1; }

.kpi-label {
  font-size: 0.8rem;
  color: var(--text-color-secondary);
  margin-bottom: 0.4rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.kpi-value {
  font-size: 1.65rem;
  font-weight: 800;
  background: var(--primary-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -1px;
  line-height: 1;
}

.kpi-value.success {
  background: var(--success-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.kpi-value.danger {
  background: var(--danger-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Section Header ──────────────────────────────────────── */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.section-header h3 { font-size: 1rem; font-weight: 700; color: var(--text-color); }

.section-header .view-all {
  color: var(--primary);
  font-size: 0.85rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.3rem;
  transition: all var(--transition-fast);
}

.section-header .view-all:hover { color: var(--primary-dark); gap: 0.5rem; }

/* ── Text utilities ──────────────────────────────────────── */
.text-success  { color: var(--success) !important; }
.text-danger   { color: var(--danger) !important; }
.text-warning  { color: var(--warning) !important; }
.text-info     { color: var(--info) !important; }

/* ── Charts ──────────────────────────────────────────────── */
.charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
@media (max-width: 768px) { .charts-row { grid-template-columns: 1fr; } }
.chart-container { height: 280px; position: relative; }

/* ── PrimeNG Overrides ─────────────────────────────────────── */
.p-card {
  border-radius: var(--radius-lg) !important;
  box-shadow: var(--shadow-md) !important;
  border: 1px solid rgba(139, 92, 246, 0.1) !important;
}

.p-button {
  border-radius: var(--radius-lg) !important;
  font-weight: 600 !important;
  transition: all var(--transition-base) !important;
}

.p-button:not(.p-button-outlined):not(.p-button-text):not(.p-button-link) {
  background: var(--primary-gradient) !important;
  border: none !important;
}

.p-button:hover { box-shadow: var(--shadow-glow) !important; transform: translateY(-1px); }

.p-inputtext,
.p-inputnumber-input {
  border-radius: var(--radius-md) !important;
  border: 2px solid rgba(139, 92, 246, 0.2) !important;
  transition: all var(--transition-base) !important;
}

.p-inputtext:focus,
.p-inputnumber-input:focus {
  border-color: var(--primary) !important;
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1) !important;
}

.p-select { border-radius: var(--radius-md) !important; border: 2px solid rgba(139, 92, 246, 0.2) !important; }

.p-datatable .p-datatable-thead > tr > th {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(168, 139, 250, 0.08) 100%) !important;
  font-weight: 700 !important;
  border-bottom: 2px solid rgba(139, 92, 246, 0.15) !important;
}

.p-datatable .p-datatable-tbody > tr:hover {
  background: linear-gradient(90deg, rgba(139, 92, 246, 0.04) 0%, rgba(168, 139, 250, 0.04) 100%) !important;
}

.p-tag { border-radius: var(--radius-full) !important; font-weight: 700 !important; padding: 0.375rem 0.875rem !important; }

.p-dialog .p-dialog-header {
  background: var(--primary-gradient) !important;
  color: white !important;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0 !important;
}

/* ── Responsive ──────────────────────────────────────────── */
@media (max-width: 768px) {
  .page-container { padding: 1.25rem; }
  .kpi-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
  .kpi-card { padding: 1.25rem; }
  .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .page-header h1 { font-size: 1.5rem; }
}

@media (max-width: 480px) {
  .kpi-grid { grid-template-columns: 1fr; }
}
